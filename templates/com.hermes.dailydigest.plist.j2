<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hermes.dailydigest</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{ target_home }}/.hermes/bin/hermes-daily-digest.sh</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{ target_home }}</string>
        <key>PATH</key>
        <string>{{ hermes_path_prefix }}:{{ ansible_facts['env']['PATH'] | default('/usr/bin:/bin') }}</string>
    </dict>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>{{ target_home }}/.hermes/logs/dailydigest.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>{{ target_home }}/.hermes/logs/dailydigest.stderr.log</string>
</dict>
</plist>
