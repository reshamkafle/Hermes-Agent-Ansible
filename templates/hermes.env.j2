OLLAMA_API_BASE="{{ ollama_base_url }}"
FIRECRAWL_API_KEY="{{ firecrawl_api_key }}"
{% if firecrawl_use_browser_auth | default(false) | bool %}
FIRECRAWL_USE_BROWSER_AUTH="true"
{% endif %}
TELEGRAM_BOT_TOKEN="{{ telegram_bot_token }}"
TELEGRAM_ALLOWED_USERS="{{ telegram_allowed_users | join(',') }}"
TELEGRAM_HOME_CHANNEL="{{ telegram_chat_id }}"
TELEGRAM_SEND_USERS="{{ (telegram_send_users | default(telegram_allowed_users)) | join(',') }}"
