#!/usr/bin/env bash
set -euo pipefail
export HOME="{{ target_home }}"
export HERMES_HOME="{{ target_home }}/.hermes"
export PATH="{{ hermes_path_prefix }}:${PATH:-/usr/bin:/bin}"
if [[ -f "${HERMES_HOME}/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${HERMES_HOME}/.env"
  set +a
fi
exec "{{ hermes_cmd }}" "$@"
