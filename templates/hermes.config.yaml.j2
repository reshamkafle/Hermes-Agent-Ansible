{% set ctx = hermes_model_context_length | default(65536) | int %}
model:
  default: "{{ lmstudio_hermes_model | default(lmstudio_runtime_model | default(lmstudio_effective_model)) }}"
  provider: "{{ hermes_model_provider | default('custom') }}"
  base_url: "{{ lmstudio_base_url }}"
  api_key: "{{ hermes_model_api_key | default('lm-studio', true) }}"
  api_mode: chat_completions
  context_length: {{ ctx }}
# Side tasks must inherit the main LM Studio endpoint (provider: main) with the same context window.
auxiliary:
  compression:
    provider: "main"
    context_length: {{ ctx }}
  web_extract:
    provider: "main"
    context_length: {{ ctx }}
  session_search:
    provider: "main"
    context_length: {{ ctx }}
  vision:
    provider: "main"
    context_length: {{ ctx }}
gateway:
  enabled: true
  platform: "telegram"
  allow_all_users: false
cron:
  wrap_response: false
web:
  backend: firecrawl
  search_backend: firecrawl
  extract_backend: firecrawl
{% if firecrawl_use_browser_auth | default(false) | bool %}
browser:
  cloud_provider: firecrawl
{% endif %}
